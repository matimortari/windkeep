generator client {
  provider = "prisma-client"
  output   = "../../.data/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String
  image              String?
  apiToken           String?              @unique
  apiTokenExpiresAt  DateTime?
  orgMemberships     OrgMembership[]
  projectMemberships ProjectMembership[]
  invitations        Invitation[]         @relation("InvitedByUser")
  auditLogs          AuditLog[]
  secretHistory      SecretValueHistory[]
  accounts           Account[]
  serviceTokens      ServiceToken[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model Organization {
  id                     String          @id @default(cuid())
  name                   String
  description            String?
  website                String?
  wrappedEncryptionKey   String
  encryptionKeyVersion   Int             @default(1)
  encryptionKeyUpdatedAt DateTime        @default(now())
  memberships            OrgMembership[]
  projects               Project[]
  invitations            Invitation[]    @relation("OrgInvitations")
  auditLogs              AuditLog[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model OrgMembership {
  userId    String
  orgId     String
  role      Role         @default(MEMBER)
  isActive  Boolean      @default(false)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@id([userId, orgId])
}

model Project {
  id            String              @id @default(cuid())
  name          String
  slug          String
  description   String?
  website       String?
  orgId         String
  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  secrets       Secret[]
  memberships   ProjectMembership[]
  serviceTokens ServiceToken[]
  auditLogs     AuditLog[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([slug, orgId])
}

model ProjectMembership {
  userId    String
  projectId String
  role      Role     @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, projectId])
}

model Secret {
  id          String        @id @default(cuid())
  key         String
  description String?
  tags        String[]      @default([])
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values      SecretValue[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([key, projectId])
}

model SecretValue {
  id          String               @id @default(cuid())
  secretId    String
  environment Environment
  value       String
  secret      Secret               @relation(fields: [secretId], references: [id], onDelete: Cascade)
  history     SecretValueHistory[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([secretId, environment])
}

model SecretValueHistory {
  id            String      @id @default(cuid())
  secretValueId String
  secretValue   SecretValue @relation(fields: [secretValueId], references: [id], onDelete: Cascade)
  value         String
  changedBy     String?
  changedByUser User?       @relation(fields: [changedBy], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())

  @@index([secretValueId, createdAt])
}

model ServiceToken {
  id          String        @id @default(cuid())
  name        String
  tokenHash   String        @unique
  environment Environment[]
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   String
  user        User          @relation(fields: [createdBy], references: [id])
  auditLogs   AuditLog[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
}

model Invitation {
  id          String       @id @default(cuid())
  email       String
  role        Role         @default(MEMBER)
  orgId       String
  token       String       @unique
  org         Organization @relation("OrgInvitations", fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy   User         @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@unique([email, orgId])
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  serviceTokenId String?
  orgId          String?
  projectId      String?
  action         String
  resource       String?
  description    String?
  metadata       Json?
  ip             String
  ua             String
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  serviceToken   ServiceToken? @relation(fields: [serviceTokenId], references: [id], onDelete: SetNull)
  org            Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([orgId, createdAt])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([serviceTokenId, createdAt])
  @@index([action, createdAt])
}
